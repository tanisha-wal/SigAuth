PORT=4100
FRONTEND_URL=http://localhost:4101

IDP_ISSUER_URL=http://localhost:8000
IDP_CLIENT_ID=your-logistica-client-id
IDP_REDIRECT_URI=http://localhost:4101/auth/callback
POST_LOGOUT_REDIRECT_URI=http://localhost:4101

APP_SESSION_COOKIE_NAME=logistica_session
APP_SESSION_SECRET=change-me-logistica-session-secret
APP_SESSION_TTL_SECONDS=28800
APP_SESSION_COOKIE_SECURE=false

LOGISTICA_ADMIN_APP_ROLES=app:admin,admin
LOGISTICA_DELIVERY_AGENT_APP_ROLES=app:delivery_agent,delivery_agent,agent
LOGISTICA_END_USER_APP_ROLES=app:end_user,end_user,user,customer
